{
  "name": "heiwa-dj",
  "private": false,
  "version": "1.0.0",
  "description": "Heiwa DJ desktop app with local Strudel runtime and Ollama model control",
  "license": "Apache-2.0",
  "author": "Devon McGregor",
  "repository": {
    "type": "git",
    "url": "https://github.com/Strategizing/heiwa-dj.git"
  },
  "bugs": {
    "url": "https://github.com/Strategizing/heiwa-dj/issues"
  },
  "homepage": "https://github.com/Strategizing/heiwa-dj#readme",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "setup": "ollama pull qwen2.5-coder:7b",
    "dev": "concurrently \"pnpm --filter server dev\" \"pnpm --filter ui dev\"",
    "dev:local": "concurrently \"pnpm --filter server dev -- --local\" \"pnpm --filter ui dev\"",
    "heiwa:start": "bash ./scripts/heiwa-start.sh",
    "heiwa:start:local": "bash ./scripts/heiwa-start.sh --local",
    "heiwa:start:embedded": "bash ./scripts/heiwa-start.sh --local --embedded",
    "heiwa:start:prod": "bash ./scripts/heiwa-start.sh --prod",
    "heiwa:start:prod:embedded": "bash ./scripts/heiwa-start.sh --prod --local --embedded",
    "heiwa:stop": "bash ./scripts/heiwa-stop.sh",
    "heiwa:app:build": "pnpm desktop:build && bash ./scripts/create-heiwa-app.sh",
    "desktop:dev": "pnpm --filter desktop dev",
    "desktop:build": "pnpm --filter desktop build:mac",
    "build": "pnpm --filter server build && pnpm --filter ui build",
    "typecheck": "pnpm --filter server typecheck && pnpm --filter ui typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
